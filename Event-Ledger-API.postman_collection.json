            "url": { "raw": "{{baseUrl}}/events", "host": ["{{baseUrl}}"], "path": ["events"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"evt-zero\",\n  \"accountId\": \"acct-123\",\n  \"type\": \"CREDIT\",\n  \"amount\": 0,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T10:00:00Z\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "POST - Negative amount (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/events", "host": ["{{baseUrl}}"], "path": ["events"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"evt-neg\",\n  \"accountId\": \"acct-123\",\n  \"type\": \"CREDIT\",\n  \"amount\": -50.00,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T10:00:00Z\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "POST - Invalid type TRANSFER (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/events", "host": ["{{baseUrl}}"], "path": ["events"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"evt-bad-type\",\n  \"accountId\": \"acct-123\",\n  \"type\": \"TRANSFER\",\n  \"amount\": 100.00,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T10:00:00Z\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "POST - Missing eventTimestamp (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/events", "host": ["{{baseUrl}}"], "path": ["events"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"evt-no-ts\",\n  \"accountId\": \"acct-123\",\n  \"type\": \"CREDIT\",\n  \"amount\": 100.00,\n  \"currency\": \"USD\"\n}"
            }
          },
          "response": []

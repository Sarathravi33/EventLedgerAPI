              "raw": "{\n  \"eventId\": \"evt-bad-1\",\n  \"type\": \"CREDIT\",\n  \"amount\": 100.00,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T10:00:00Z\"\n}"
            }
          },
          "response": []

            "url": { "raw": "{{baseUrl}}/events", "host": ["{{baseUrl}}"], "path": ["events"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"evt-102\",\n  \"accountId\": \"acct-456\",\n  \"type\": \"DEBIT\",\n  \"amount\": 300.00,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T11:00:00Z\"\n}"

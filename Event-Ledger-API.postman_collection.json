            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"evt-101\",\n  \"accountId\": \"acct-456\",\n  \"type\": \"CREDIT\",\n  \"amount\": 1000.00,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T09:00:00Z\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "POST - Submit DEBIT to acct-456",
          "request": {
            "method": "POST",
